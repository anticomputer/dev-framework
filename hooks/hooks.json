{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "type": "command",
        "bash": "bash \"$PLUGIN_ROOT/hooks/lib/session-start.sh\"",
        "timeout": 20
      }
    ],
    "preToolUse": [
      {
        "type": "command",
        "matcher": "Edit|Write|MultiEdit|edit|create|str_replace|str_replace_editor",
        "bash": "bash \"$PLUGIN_ROOT/hooks/lib/pre-tool-use.sh\"",
        "timeout": 20
      }
    ],
    "postToolUse": [
      {
        "type": "command",
        "matcher": "Edit|Write|MultiEdit|edit|create|str_replace|str_replace_editor",
        "bash": "bash \"$PLUGIN_ROOT/hooks/lib/post-tool-use.sh\"",
        "timeout": 120
      }
    ],
    "agentStop": [
      {
        "type": "command",
        "bash": "bash \"$PLUGIN_ROOT/hooks/lib/stop-gate.sh\"",
        "timeout": 600
      }
    ]
  }
}
