#!/usr/bin/env bash
# df — control and launch Copilot CLI with the dev-framework.
#
#   df [copilot args...]      launch copilot with the framework active (honors a repo's
#                             .dev-framework.yml profile; defaults to `standard`)
#   df strict   [args...]     launch in strict profile   (hard gate; deny protected edits)
#   df standard [args...]     launch in standard profile (gate blocks on test/type fails)
#   df advisory [args...]     launch in advisory profile (feedback only; never blocks)
#   df off      [args...]     launch with the framework dormant
#   df init [--force] [--profile P]   write a tailored .dev-framework.yml for this repo
#   df status                 show the resolved profile and detected tooling here
#   df help                   show this help
set -euo pipefail

SELF="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
FW="$(cd "$SELF/.." && pwd)"
. "$FW/hooks/lib/common.sh"

df_root_for_cwd() {
  git rev-parse --show-toplevel 2>/dev/null || pwd
}

launch() { # PROFILE_OR_EMPTY  args...
  local prof="$1"; shift || true
  command -v copilot >/dev/null 2>&1 || { echo "df: 'copilot' not found on PATH." >&2; exit 127; }
  if [ -n "$prof" ]; then
    DEV_FRAMEWORK="$prof" exec copilot "$@"
  else
    # No explicit profile: honor a repo .dev-framework.yml if present, else default on.
    local root; root="$(df_root_for_cwd)"
    if [ -f "$root/.dev-framework.yml" ]; then exec copilot "$@"
    else DEV_FRAMEWORK="standard" exec copilot "$@"; fi
  fi
}

cmd_status() {
  local root; root="$(df_root_for_cwd)"
  COPILOT_PROJECT_DIR="$root" DEV_FRAMEWORK="${DEV_FRAMEWORK:-}" bash -c '
    . "'"$FW"'/hooks/lib/common.sh"
    cfg="$(df_config_file)"
    echo "dev-framework status"
    echo "  repo root        : '"$root"'"
    if [ -f "$cfg" ]; then echo "  config           : $cfg (present)"
    else echo "  config           : none (.dev-framework.yml absent — run: df init)"; fi
    echo "  resolved profile : $(df_profile)   (DEV_FRAMEWORK='\''${DEV_FRAMEWORK:-}'\'')"
    echo "  tests            : $(df_cfg test "$(df_detect_test)")"
    echo "  type-check       : $(df_cfg typecheck "$(df_detect_typecheck)")"
    if df_precommit_active; then echo "  per-file checks  : pre-commit (handles format + lint for all file types)"; fi
    echo "  gate             : block=$(df_opt gate_block_on_failure) scope=$(df_opt gate_scope) skip-unchanged=$(df_opt gate_skip_unchanged) lint-changed=$(df_opt gate_lint_changed) max-blocks=$(df_opt gate_max_blocks)"
    echo "  protect          : mode=$(df_opt protect_mode) off=$(df_opt protect_off)"
    ex="$(df_cfg exclude "")"; echo "  exclude          : ${ex:-<none>}"
    echo "  format/lint by language present in this repo:"
    any=""
    for ext in $(df_exts_present); do
      f="x.$ext"; fc="$(df_lang_cmd format "$f")"; lc="$(df_lang_cmd lint "$f")"
      [ -n "$fc$lc" ] || continue
      any=1
      printf "    .%-6s format: %-28s lint: %s\n" "$ext" "${fc:-—}" "${lc:-—}"
    done
    [ -n "$any" ] || echo "    (no formatters/linters detected for the file types here — install tools or set format/lint)"
  '
}

cmd_init() {
  local force="" prof="standard" root cfg
  while [ $# -gt 0 ]; do
    case "$1" in
      --force) force=1 ;;
      --profile) shift; prof="${1:-standard}" ;;
      --profile=*) prof="${1#--profile=}" ;;
      *) echo "df init: unknown option '$1'" >&2; exit 2 ;;
    esac
    shift
  done
  root="$(df_root_for_cwd)"; cfg="$root/.dev-framework.yml"
  if [ -f "$cfg" ] && [ -z "$force" ]; then
    echo "df init: $cfg already exists (use --force to overwrite)." >&2; exit 1
  fi
  COPILOT_PROJECT_DIR="$root" bash -c '
    . "'"$FW"'/hooks/lib/common.sh"
    t="$(df_detect_test)"; tc="$(df_detect_typecheck)"
    langs="$(df_exts_present | tr "\n" " ")"
    pc="auto"; df_precommit_active && pc="auto (pre-commit detected — handles per-file format+lint)"
  cat > "'"$cfg"'" <<YML
# .dev-framework.yml — generated by \`df init\`. Edit freely; all keys are optional.
# Presence of this file activates the framework for Copilot sessions in this repo.
# File types seen here: ${langs}

# Intensity: off | advisory | standard | strict
#   advisory = feedback only, never blocks   standard = gate blocks on failing tests
#   strict   = also blocks on lint of changed files + denies protected-path edits
profile: '"$prof"'

# --- Commands (blank = auto-detect; {file}/{files} are substituted) ---------
# Auto-detect covers many languages and only runs installed tools. Per-language
# overrides use the extension as a suffix, e.g.  format.py: ruff format {file}
test: ${t}
typecheck: ${tc}
format:        # global formatter ({file} substituted); blank = auto per file extension
lint:          # global linter ({file} substituted);   blank = auto per file extension
precommit: ${pc%% *}   # auto | off — use .pre-commit-config.yaml when present

# --- Live enforcement ------------------------------------------------------
format_on_edit: true
lint_on_edit: true

# --- Completion gate -------------------------------------------------------
gate_run_typecheck: true
gate_run_tests: true
gate_skip_unchanged: true     # skip the gate if no files changed this session
gate_scope: all               # all | changed  (changed uses test_changed below)
# test_changed: <cmd {files}> # scoped command when gate_scope: changed
# gate_timeout: 300           # seconds per gate command (needs \`timeout\`)
gate_max_blocks: 3

# --- Protected paths (preToolUse guardrail) --------------------------------
# protect:      # space-separated globs; blank = sensible defaults (lockfiles, .env,
#               # vendored, generated, build output). Set protect_off: true to disable.
protect_off: false

# --- Misc ------------------------------------------------------------------
# exclude:      # globs to skip for format/lint (e.g. **/migrations/**)
# style_guide:  # path to a style guide to follow (auto-discovered if blank)
YML
  '
  echo "Wrote $cfg (profile: $prof). Detected: test='$(COPILOT_PROJECT_DIR="$root" bash -c ". \"$FW/hooks/lib/common.sh\"; df_detect_test")'."
  echo "Review it, then start a session in this repo with:  copilot   (or: df)"
}

case "${1:-}" in
  ""|run)            shift || true; launch "" "$@" ;;
  strict|standard|advisory|off)
                     prof="$1"; shift; launch "$prof" "$@" ;;
  on)                shift; launch "standard" "$@" ;;
  init)              shift; cmd_init "$@" ;;
  status)            cmd_status ;;
  version|--version|-v)
                     v="$(python3 -c "import json;print(json.load(open('$FW/plugin.json'))['version'])" 2>/dev/null || echo '?')"
                     echo "dev-framework $v" ;;
  help|-h|--help)    sed -n '2,17p' "${BASH_SOURCE[0]}" | sed 's/^# \{0,1\}//' ;;
  *)                 launch "" "$@" ;;   # treat unknown leading arg as copilot args
esac
